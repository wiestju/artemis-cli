# Copy this file to .env and fill in your credentials.
# .env is gitignored and never committed.

# Auth option 1: Token (SSO / KIT university login)
# 1. Log in via browser at https://artemis.cs.kit.edu
# 2. Open DevTools → Application → Cookies → copy the 'jwt' value
ARTEMIS_TOKEN=

# Auth option 2: Password (internal Artemis accounts only, not KIT)
ARTEMIS_USERNAME=
ARTEMIS_PASSWORD=

# Server — defaults to KIT if omitted
ARTEMIS_SERVER=https://artemis.cs.kit.edu

# All IDs below are optional — auto-detected from the API if omitted
ARTEMIS_COURSE_ID=
ARTEMIS_EXERCISE_ID=
ARTEMIS_PARTICIPATION_ID=

# AI grading (optional) — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
